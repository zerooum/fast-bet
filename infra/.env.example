# Fast-Bet local infrastructure environment.
#
# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored; this `.env.example` is committed.

# --- Postgres ---
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me-superuser
POSTGRES_PORT=5432

# Per-service Postgres role passwords (consumed by infra/postgres/init/01-databases.sql)
IDENTITY_SVC_PASSWORD=change-me-identity
CATALOG_SVC_PASSWORD=change-me-catalog
WALLET_SVC_PASSWORD=change-me-wallet
BETS_SVC_PASSWORD=change-me-bets

# --- Kafka ---
KAFKA_PORT=9092

# --- Redis ---
REDIS_PORT=6379

# --- Identity service trust boundary ---
# Comma-separated CIDR list of proxies allowed to set X-Forwarded-For on
# public Identity routes. Empty (default) = trust nobody, always use the
# direct TCP peer for rate-limit keying. Set this to the gateway's
# address(es) in compose / k8s.
IDENTITY_TRUSTED_PROXIES=

# Shared edge secret for the Gateway-to-Identity hop.
# Both Identity and the Gateway must be configured with the same value.
# Use a strong random string in production (e.g. openssl rand -hex 32).
# The Gateway will fail fast at startup if this is blank.
IDENTITY_EDGE_TOKEN=change-me-edge-token
