# Fast-Bet Gateway local environment.
#
# Copy this file to `.env` (same directory) and adjust as needed.
# `.env` is gitignored; this `.env.example` is committed.
# Loaded automatically by `cargo run` via `dotenvy`. In production
# (docker-compose / k8s) these variables are injected by the orchestrator
# and `.env` is not used.

GATEWAY_BIND_ADDR=0.0.0.0:8080
IDENTITY_BASE_URL=http://localhost:8081
REDIS_URL=redis://localhost:6379
SIGNUP_RATE_LIMIT=5
SIGNUP_RATE_WINDOW_SECS=60

# Shared edge secret injected on every Identity upstream request.
# Must match IDENTITY_EDGE_TOKEN set in services/identity.
# Use a strong random string in production (e.g. openssl rand -hex 32).
IDENTITY_EDGE_TOKEN=change-me-edge-token

# Optional: tracing filter (see tracing-subscriber EnvFilter syntax)
# RUST_LOG=info,fastbet_gateway=debug
